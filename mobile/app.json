{
    "expo": {
        "name": "SafeDeliver",
        "slug": "safedeliver",
        "version": "2.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "splash": {
            "image": "./assets/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#1A6B5A"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "co.safedeliver.seller"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/adaptive-icon.png",
                "backgroundColor": "#1A6B5A"
            },
            "package": "co.safedeliver.seller"
        }
    }
}