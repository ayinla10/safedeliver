# ─────────────────────────────────────────────
# SafeDeliver Backend — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (Supabase) ──────────────────────
# Get from Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── JWT Auth ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ── Admin Account ────────────────────────────
# Used when seeding the admin account via: node db/migrate.js
# REQUIRED — no default. Use a strong password.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Paystack ─────────────────────────────────
# Get from https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX

# ── Supabase Storage ─────────────────────────
# Get from Supabase → Project Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Africa's Talking (SMS) ───────────────────
# Get from https://account.africastalking.com
AT_API_KEY=CHANGE_ME
AT_USERNAME=safedeliver

# ── Web Push (VAPID) ─────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_EMAIL=mailto:admin@yourdomain.com

# ── Frontend URL ─────────────────────────────
# Your Vercel deployment URL — used in SMS links and CORS
FRONTEND_URL=https://safedeliver.vercel.app

# ── Migration Secret ─────────────────────────
# Used to protect /api/v1/transactions/sim-confirm in dev
# Only needed locally — sim-confirm is blocked in production
MIGRATE_SECRET=CHANGE_ME_RANDOM_STRING

# ── Email (Resend) ───────────────────────────
# Sign up free at https://resend.com — 3,000 emails/month free
# Without this, password reset and transaction emails are simulated (logged only)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
# The "From" address — must be a verified domain in your Resend account
EMAIL_FROM=SafeDeliver <noreply@yourdomain.com>

# ── Sentry Error Monitoring ──────────────────
# Sign up free at https://sentry.io → Create project → Node.js
# Without this, errors are only logged to Render/stdout
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX
